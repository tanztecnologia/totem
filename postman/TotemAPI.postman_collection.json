      "name": "Auth",
      "item": [
        {
          "name": "Register (Tenant + Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json && json.token) { pm.collectionVariables.set('token', json.token); pm.environment.set('token', json.token); }",
                  "  if (json && json.tenantId) { pm.collectionVariables.set('tenantId', json.tenantId); pm.environment.set('tenantId', json.tenantId); }",
                  "  if (json && json.userId) { pm.collectionVariables.set('userId', json.userId); pm.environment.set('userId', json.userId); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantName\": \"{{tenantName}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
